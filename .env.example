# Environment
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# NextAuth Configuration
# For development with subdomain (e.g., app.localhost:3000):
# NEXTAUTH_URL=http://app.localhost:3000
# For production:
NEXTAUTH_URL=https://app.aqarna-dev.com
NEXTAUTH_SECRET=your-secure-random-secret-here-min-32-chars

# Cookie Domain for subdomain sharing
# Production: .aqarna-dev.com (shares cookies across subdomains)
# Development: leave undefined or .localhost
COOKIE_DOMAIN=.aqarna-dev.com

# API Configuration
NEXT_PUBLIC_API_BASE_URL=https://aqarna-dev.com/api/v1


